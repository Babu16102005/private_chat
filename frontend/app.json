{
  "expo": {
    "name": "Kiba",
    "slug": "Kiba",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/kibabg_centered.png",
    "scheme": "chatapp",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/kibabg_centered.png",
      "resizeMode": "contain",
      "backgroundColor": "#05000D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "url": "https://u.expo.dev/b1944efe-bfdd-404f-8579-4a80b41bf61d",
      "enabled": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chatapplication.app",
      "associatedDomains": [
        "applinks:chatapplication.app"
      ],
      "bitcode": false,
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/kibabg_centered.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.chatapplication.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "chatapp",
              "host": "accept"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ],
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "favicon": "./assets/kibabg_centered.png"
    },
    "plugins": [
      "expo-video",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone"
        }
      ],
      "expo-audio",
      "expo-asset",
      "expo-mail-composer"
    ],
    "owner": "babu_b",
    "extra": {
      "eas": {
        "projectId": "b1944efe-bfdd-404f-8579-4a80b41bf61d"
      }
    }
  }
}
